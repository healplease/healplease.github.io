{
  "name": "healplease.github.io",
  "version": "0.1.0",
  "homepage": "https://healplease.github.io",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "^2.1.3",
    "sass": "^1.57.1"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
